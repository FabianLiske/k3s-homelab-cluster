apiVersion: v1
kind: Secret
metadata:
  name: ntfy-secret
  namespace: svc-ntfy
type: Opaque
stringData:
  NTFY_AUTH_USERS: "admin:<bcrypt-password-hash>:admin,media-backup:<bcrypt-password-hash>:user,truenas:<bcrypt-password-hash>:user"
  NTFY_AUTH_TOKENS: "admin:tk_replacewith32chars:Homelab automation,media-backup:tk_replacewith32chars:Media backup,truenas:tk_replacewith32chars:TrueNAS alerts"
  NTFY_ADMIN_PASSWORD: "<initial-admin-password>"
  NTFY_MEDIA_BACKUP_PASSWORD: "<initial-media-backup-password>"
  NTFY_TRUENAS_PASSWORD: "<initial-truenas-password>"
