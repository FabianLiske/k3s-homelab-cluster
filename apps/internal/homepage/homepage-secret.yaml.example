apiVersion: v1
kind: Secret
metadata:
  name: homepage-secret
  namespace: svc-homepage
type: Opaque
stringData:
  settings.yaml: |
    title: Home
    description: Interne Startseite fuer das Homelab
    headerStyle: clean
    language: de
    target: _blank
    color: slate
    background:
      image: /images/shaded-landscape.webp
      opacity: 40
      brightness: 60
    hideVersion: true
    statusStyle: dot
    layout:
      Media:
        style: row
        columns: 4
      Tools:
        style: row
        columns: 3
      Monitoring:
        style: row
        columns: 3
      Games:
        style: row
        columns: 2
    quicklaunch:
      searchDescriptions: true
      provider: duckduckgo
      target: _blank
  services.yaml: |
    # Hinweis:
    # - Alle potentiell sensiblen Homepage-Dateien leben absichtlich in diesem Secret.
    # - Die Startseite funktioniert sofort mit Links, Site-Monitoring und Pod-Stats.
    # - Native Widgets kannst du spaeter pro Dienst aktivieren, indem du den
    #   auskommentierten widget-Block aktivierst und den passenden Key eintraegst.

    - Media:
        - Jellyfin:
            href: https://jellyfin.intern.rohrbom.be
            description: Medienserver
            siteMonitor: https://jellyfin.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=jellyfin
            # widget:
            #   type: jellyfin
            #   version: 2
            #   url: https://jellyfin.intern.rohrbom.be
            #   key: REPLACE_ME_JELLYFIN_API_KEY
        - Seerr:
            href: https://seerr.intern.rohrbom.be
            description: Medienanfragen
            siteMonitor: https://seerr.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=seerr
            # widget:
            #   type: seerr
            #   url: https://seerr.intern.rohrbom.be
            #   key: REPLACE_ME_SEERR_API_KEY
        - Radarr:
            href: https://radarr.intern.rohrbom.be
            description: Filme
            siteMonitor: https://radarr.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=radarr
            # widget:
            #   type: radarr
            #   url: https://radarr.intern.rohrbom.be
            #   key: REPLACE_ME_RADARR_API_KEY
        - Sonarr:
            href: https://sonarr.intern.rohrbom.be
            description: Serien
            siteMonitor: https://sonarr.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=sonarr
            # widget:
            #   type: sonarr
            #   url: https://sonarr.intern.rohrbom.be
            #   key: REPLACE_ME_SONARR_API_KEY
        - Lidarr:
            href: https://lidarr.intern.rohrbom.be
            description: Musik
            siteMonitor: https://lidarr.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=lidarr
            # widget:
            #   type: lidarr
            #   url: https://lidarr.intern.rohrbom.be
            #   key: REPLACE_ME_LIDARR_API_KEY
        - Readarr:
            href: https://readarr.intern.rohrbom.be
            description: Buecher
            siteMonitor: https://readarr.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=readarr
            # widget:
            #   type: readarr
            #   url: https://readarr.intern.rohrbom.be
            #   key: REPLACE_ME_READARR_API_KEY
        - Bazarr:
            href: https://bazarr.intern.rohrbom.be
            description: Untertitel
            siteMonitor: https://bazarr.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=bazarr
            # widget:
            #   type: bazarr
            #   url: https://bazarr.intern.rohrbom.be
            #   key: REPLACE_ME_BAZARR_API_KEY
        - Prowlarr:
            href: https://prowlarr.intern.rohrbom.be
            description: Indexer
            siteMonitor: https://prowlarr.intern.rohrbom.be
            namespace: svc-media
            podSelector: app=prowlarr
            # widget:
            #   type: prowlarr
            #   url: https://prowlarr.intern.rohrbom.be
            #   key: REPLACE_ME_PROWLARR_API_KEY
        - qBittorrent:
            href: https://qbit.intern.rohrbom.be
            description: Torrent Client
            siteMonitor: https://qbit.intern.rohrbom.be
            namespace: svc-qbittorrent
            podSelector: app=qbittorrent
            # widget:
            #   type: qbittorrent
            #   url: https://qbit.intern.rohrbom.be
            #   username: REPLACE_ME_QBITTORRENT_USERNAME
            #   password: REPLACE_ME_QBITTORRENT_PASSWORD

    - Tools:
        - Paperless:
            href: https://paperless.intern.rohrbom.be
            description: Dokumentenarchiv
            siteMonitor: https://paperless.intern.rohrbom.be
            namespace: svc-paperless-ngx
            podSelector: app=paperless-ngx,component=webserver
            # widget:
            #   type: paperlessngx
            #   url: https://paperless.intern.rohrbom.be
            #   key: REPLACE_ME_PAPERLESS_TOKEN
        - Trilium:
            href: https://trilium.intern.rohrbom.be
            description: Notizen
            siteMonitor: https://trilium.intern.rohrbom.be
            namespace: svc-trilium
            podSelector: app=trilium
            # widget:
            #   type: trilium
            #   url: https://trilium.intern.rohrbom.be
            #   key: REPLACE_ME_TRILIUM_ETAPI_TOKEN
        - Linkding:
            href: https://ld.intern.rohrbom.be
            description: Bookmarks
            siteMonitor: https://ld.intern.rohrbom.be
            namespace: svc-linkding
            podSelector: app=linkding
        - Stirling PDF:
            href: https://pdf.intern.rohrbom.be
            description: PDF Werkzeuge
            siteMonitor: https://pdf.intern.rohrbom.be
            namespace: svc-stirling
            podSelector: app=stirling-pdf

    - Monitoring:
        - Grafana:
            href: https://grafana.mon.rohrbom.be
            description: Dashboards
            siteMonitor: https://grafana.mon.rohrbom.be
            namespace: ops-monitoring
            podSelector: app=grafana
            # widget:
            #   type: grafana
            #   version: 2
            #   url: https://grafana.mon.rohrbom.be
            #   username: REPLACE_ME_GRAFANA_USERNAME
            #   password: REPLACE_ME_GRAFANA_PASSWORD
        - Prometheus:
            href: https://prometheus.mon.rohrbom.be
            description: Metriken und Targets
            siteMonitor: https://prometheus.mon.rohrbom.be
            namespace: ops-monitoring
            podSelector: app=prometheus
            widget:
              type: prometheus
              url: https://prometheus.mon.rohrbom.be
        - Longhorn:
            href: https://longhorn.cluster.rohrbom.be
            description: Cluster Storage
            siteMonitor: https://longhorn.cluster.rohrbom.be
            namespace: longhorn-system
            podSelector: ""
            # Das Longhorn-Widget wird ueber settings.yaml providers.longhorn konfiguriert,
            # sobald URL und optional Zugangsdaten hinterlegt sind.

    - Games:
        - Pelican:
            href: https://pelican.intern.rohrbom.be
            description: Gameserver Panel
            siteMonitor: https://pelican.intern.rohrbom.be
            namespace: svc-games
            podSelector: app=pelican
  widgets.yaml: |
    - search:
        provider: duckduckgo
        target: _blank
    - kubernetes:
        cluster:
          show: true
          cpu: true
          memory: true
          showLabel: true
          label: cluster
        nodes:
          show: true
          cpu: true
          memory: true
          showLabel: true
