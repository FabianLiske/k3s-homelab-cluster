apiVersion: v1
kind: Secret
metadata:
  name: qbittorrent-wireguard
  namespace: svc-media
type: Opaque
stringData:
  wg0.conf: |
    [Interface]
    PrivateKey =
    Address =
    DNS =

    [Peer]
    PublicKey =
    AllowedIPs = 0.0.0.0/0
    Endpoint =

  wg0-pre.sh: |
    #!/bin/sh
    set -eu
    echo "[wg0-pre] checking stale wg0..."
    if ip link show wg0 >/dev/null 2>&1; then
      echo "[wg0-pre] deleting stale wg0"
      ip link del wg0 || true
    fi