apiVersion: v1
kind: Secret
metadata:
  name: pelican-secret
  namespace: svc-games
type: Opaque
stringData:
  # Optional: provide a fixed key before first start if you do not want
  # Pelican to auto-generate and persist it in /pelican-data/.env.
  APP_KEY: "replace-with-32-char-app-key"
  # Optional: only needed if you later expose Pelican without BEHIND_PROXY=true.
  LE_EMAIL: "replace-with-letsencrypt-contact@example.com"
